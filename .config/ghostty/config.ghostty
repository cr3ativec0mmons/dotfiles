
# Empty values reset the configuration to the default value
font-family = "JetBrains Mono"
theme = dark:Belafonte Night,light:Gruvbox Light Hard
shell-integration = "fish"
background-blur = "true"
notify-on-command-finish = "unfocused"
notify-on-command-finish-action = "bell"
shell-integration-features = "true"
command = "/home/linuxbrew/.linuxbrew/bin/fish --login --interactive"
